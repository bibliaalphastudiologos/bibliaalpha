# ============================================================
# Bíblia Alpha — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite .env.local — ele está no .gitignore.

# Chave da API Gemini (obrigatória para tradução automática de comentários)
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Chave da API.Bible (opcional — habilita traduções adicionais)
# Obtenha gratuitamente em: https://scripture.api.bible/
VITE_BIBLE_API_KEY=
