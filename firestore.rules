rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn()
        && request.auth.token.email == 'analista.ericksilva@gmail.com';
    }

    function isAdmin() {
      return isSuperAdmin() || (
        isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
    }

    function isValidUser(data) {
      let validEmail = data.get('email', '') is string && data.get('email', '').size() <= 200;
      let validNome = data.get('nome', '') is string && data.get('nome', '').size() <= 200;
      let validFoto = data.get('foto', '') is string && data.get('foto', '').size() <= 2000;
      let validStatus = data.get('status', '') in ['pending', 'approved', 'blocked'];
      let validAdmin = !('isAdmin' in data) || data.isAdmin is bool;
      return validEmail && validNome && validFoto && validStatus && validAdmin;
    }

    // ── Usuários ──────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();

      allow create: if isSignedIn()
        && request.auth.uid == userId
        && isValidUser(request.resource.data)
        && request.resource.data.email == request.auth.token.email
        && (
          (isSuperAdmin() && request.resource.data.status in ['pending', 'approved'])
          || (!isSuperAdmin() && request.resource.data.status == 'pending')
        )
        && (!('isAdmin' in request.resource.data) || request.resource.data.isAdmin == false || isSuperAdmin());

      allow update: if isSignedIn()
        && isValidUser(request.resource.data)
        && (
          (isAdmin()
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasAny(['status', 'isAdmin', 'updatedAt', 'payment_status', 'access_status', 'paymentId', 'approvedAt', 'approvalDateBrasilia', 'manual_access']))
          ||
          (request.auth.uid == userId
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['nome', 'foto', 'updatedAt', 'payment_status', 'access_status', 'paymentId', 'approvedAt', 'approvalDateBrasilia']))
        );

      allow delete: if isAdmin();

      match /highlights/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
      match /notes/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
      match /tasks/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
      match /plans/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // ── Acessos (Mercado Pago + admin manual) ────────────────────
    match /access/{docId} {
      allow read: if isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() == docId;
      allow read: if isAdmin();
      allow write: if isAdmin(); // Admin pode liberar acesso manualmente
    }

    // ── Acesso via Studio Logos / payment_access ──────────────────
    match /payment_access/{docId} {
      allow read: if isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() == docId;
      allow read: if isAdmin();
      allow write: if isAdmin(); // Admin pode liberar acesso manualmente
    }

    // ── Orders ────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isSignedIn()
        && resource != null
        && resource.data.email == request.auth.token.email;
      allow read: if isAdmin();
      allow write: if false; // Somente Admin SDK (Cloud Functions)
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}