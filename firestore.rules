rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn()
        && request.auth.token.email == 'analista.ericksilva@gmail.com';
    }

    function isAdmin() {
      return isSuperAdmin() || (
        isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
    }

    function isValidUser(data) {
      let validEmail  = data.get('email', '')  is string && data.get('email', '').size()  <= 200;
      let validNome   = data.get('nome', '')   is string && data.get('nome', '').size()   <= 200;
      let validFoto   = data.get('foto', '')   is string && data.get('foto', '').size()   <= 2000;
      let validStatus = data.get('status', '') in ['pending', 'approved', 'blocked'];
      let validAdmin  = !('isAdmin' in data) || data.isAdmin is bool;
      return validEmail && validNome && validFoto && validStatus && validAdmin;
    }

    match /users/{userId} {

      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();

      allow create: if isSignedIn()
        && request.auth.uid == userId
        && isValidUser(request.resource.data)
        && request.resource.data.email == request.auth.token.email
        && (
          (isSuperAdmin() && request.resource.data.status in ['pending', 'approved'])
          || (!isSuperAdmin() && request.resource.data.status == 'pending')
        )
        && (!('isAdmin' in request.resource.data) || request.resource.data.isAdmin == false || isSuperAdmin());

      allow update: if isSignedIn()
        && isValidUser(request.resource.data)
        && (
          (isAdmin()
            && request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'isAdmin', 'updatedAt']))
          ||
          (request.auth.uid == userId
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nome', 'foto', 'updatedAt']))
        );

      allow delete: if isAdmin();

      // ── Highlights sincronizados por capítulo ──
      match /highlights/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      // ── Notas do bloco de estudos ──
      match /notes/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      // ── Tarefas do bloco de estudos ──
      match /tasks/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      // ── Progresso dos planos de leitura ──
      match /plans/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
