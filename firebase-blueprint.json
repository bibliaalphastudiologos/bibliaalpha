{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role management",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "User email address"
        },
        "nome": {
          "type": "string",
          "description": "User display name"
        },
        "foto": {
          "type": "string",
          "description": "Avatar URL"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "blocked"],
          "description": "Access control status"
        },
        "isAdmin": {
          "type": "boolean",
          "description": "Admin flag (analista.ericksilva@gmail.com is hardcoded admin but we can also flag it)"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["email", "nome", "status", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "User profiles and permissions collection"
    }
  }
}
