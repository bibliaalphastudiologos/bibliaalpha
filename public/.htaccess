# Biblia Alpha — Cache Control para Hostinger/LiteSpeed (v4)

# ─── LiteSpeed Cache ──────────────────────────────────────────────────────────
<IfModule LiteSpeed>
  <FilesMatch "^(index\.html|sw\.js|manifest\.json)$">
    Header always set X-LiteSpeed-Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

# ─── Headers de Cache ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>

  # 1. Assets Vite com hash no nome (imutaveis) — cache longo
  <FilesMatch "\.(js|css|woff2?|ttf|eot)$">
    Header always set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # 2. Imagens — cache de 1 dia
  <FilesMatch "\.(png|jpg|jpeg|gif|webp|svg|ico)$">
    Header always set Cache-Control "public, max-age=86400"
  </FilesMatch>

  # 3. index.html e manifest.json — sem cache NUNCA
  <FilesMatch "^(index\.html|manifest\.json)$">
    Header always unset Cache-Control
    Header always set Cache-Control "no-cache, no-store, must-revalidate"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
    Header always set X-LiteSpeed-Cache-Control "no-cache"
  </FilesMatch>

  # 4. sw.js — sem cache NUNCA (DEVE vir APOS a regra geral .js)
  #    Usa unset antes de set para GARANTIR que nao ha header duplicado
  <Files "sw.js">
    Header always unset Cache-Control
    Header always set Cache-Control "no-cache, no-store, must-revalidate"
    Header always unset Pragma
    Header always set Pragma "no-cache"
    Header always unset Expires
    Header always set Expires "0"
    Header always set Content-Type "application/javascript"
    Header always set X-LiteSpeed-Cache-Control "no-cache"
    Header always set Service-Worker-Allowed "/"
  </Files>

</IfModule>

# ─── Compressao Gzip ──────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript
  AddOutputFilterByType DEFLATE application/json application/manifest+json
</IfModule>

# ─── SPA Routing (React Router / Vite) ───────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !^/assets/
  RewriteCond %{REQUEST_URI} !\.(js|css|png|jpg|jpeg|gif|webp|svg|ico|woff2?|ttf|eot|json)$

  RewriteRule ^ index.html [L]
</IfModule>
